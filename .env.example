# ─── Reddit Data API ────────────────────────────────────────────────
# Create at https://www.reddit.com/prefs/apps → "create another app" → "script" type
# Once Reddit approves your registration, paste these values and rename this file to `.env`.

REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Your Reddit account — required for password grant on a "script" type app.
# (.env is gitignored. If you'd rather not store your password, see scripts/README.md
#  for switching to read-only client_credentials grant.)
REDDIT_USERNAME=
REDDIT_PASSWORD=

# Reddit REQUIRES a descriptive User-Agent. Replace YOUR_USERNAME with your Reddit handle.
REDDIT_USER_AGENT=court-report-scraper/0.1 by /u/YOUR_USERNAME


# ─── Anthropic API (for the LLM condense step) ──────────────────────
# Get one at https://console.anthropic.com/settings/keys

ANTHROPIC_API_KEY=

# Default is Haiku 4.5 — fast + cheap, ideal for bulk extraction.
# Switch to claude-sonnet-4-6 if you want higher-quality condensation at ~5x cost.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
